{
  "jobName": "ComplianceEventSummaryV2",
  "firstEffectiveDate": "2024-10-01",
  "modules": [
    {
      "type": "DataSourcing",
      "resultName": "compliance_events",
      "schema": "datalake",
      "table": "compliance_events",
      "columns": [
        "event_type",
        "status"
      ]
    },
    {
      "type": "Transformation",
      "resultName": "output",
      "sql": "SELECT COALESCE(event_type, '') AS event_type, COALESCE(status, '') AS status, COUNT(*) AS event_count, ifw_effective_date FROM compliance_events WHERE strftime('%w', ifw_effective_date) != '0' GROUP BY COALESCE(event_type, ''), COALESCE(status, ''), ifw_effective_date ORDER BY event_type, status"
    },
    {
      "type": "CsvFileWriter",
      "source": "output",
      "includeHeader": true,
      "trailerFormat": "TRAILER|{row_count}|{date}",
      "writeMode": "Overwrite",
      "lineEnding": "LF",
      "outputDirectory": "Output/poc4",
      "jobDirName": "compliance_event_summary",
      "fileName": "compliance_event_summary.csv"
    }
  ]
}
