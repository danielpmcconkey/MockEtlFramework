{
  "jobName": "BranchVisitSummaryV2",
  "firstEffectiveDate": "2024-10-01",
  "modules": [
    {
      "type": "DataSourcing",
      "resultName": "branch_visits",
      "schema": "datalake",
      "table": "branch_visits",
      "columns": [
        "branch_id"
      ]
    },
    {
      "type": "DataSourcing",
      "resultName": "branches",
      "schema": "datalake",
      "table": "branches",
      "columns": [
        "branch_id",
        "branch_name"
      ]
    },
    {
      "type": "Transformation",
      "resultName": "visit_summary",
      "sql": "SELECT bv.branch_id, b.branch_name, bv.ifw_effective_date, COUNT(*) AS visit_count FROM branch_visits bv LEFT JOIN branches b ON bv.branch_id = b.branch_id AND bv.ifw_effective_date = b.ifw_effective_date GROUP BY bv.branch_id, b.branch_name, bv.ifw_effective_date ORDER BY bv.ifw_effective_date, bv.branch_id"
    },
    {
      "type": "CsvFileWriter",
      "source": "visit_summary",
      "includeHeader": true,
      "trailerFormat": "TRAILER|{row_count}|{date}",
      "writeMode": "Append",
      "lineEnding": "LF",
      "outputDirectory": "Output/poc4",
      "jobDirName": "branch_visit_summary",
      "fileName": "branch_visit_summary.csv"
    }
  ]
}
