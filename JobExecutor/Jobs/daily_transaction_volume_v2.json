{
  "jobName": "DailyTransactionVolumeV2",
  "firstEffectiveDate": "2024-10-01",
  "modules": [
    {
      "type": "DataSourcing",
      "resultName": "transactions",
      "schema": "datalake",
      "table": "transactions",
      "columns": [
        "amount"
      ]
    },
    {
      "type": "Transformation",
      "resultName": "daily_vol",
      "sql": "SELECT ifw_effective_date, COUNT(*) AS total_transactions, ROUND(SUM(amount), 2) AS total_amount, ROUND(AVG(amount), 2) AS avg_amount FROM transactions GROUP BY ifw_effective_date ORDER BY ifw_effective_date"
    },
    {
      "type": "CsvFileWriter",
      "source": "daily_vol",
      "includeHeader": true,
      "trailerFormat": "CONTROL|{date}|{row_count}|{timestamp}",
      "writeMode": "Append",
      "lineEnding": "CRLF",
      "outputDirectory": "Output/poc4",
      "jobDirName": "daily_transaction_volume",
      "fileName": "daily_transaction_volume.csv"
    }
  ]
}
