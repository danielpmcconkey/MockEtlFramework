{
  "jobName": "MonthlyTransactionTrendV2",
  "firstEffectiveDate": "2024-10-01",
  "modules": [
    {
      "type": "DataSourcing",
      "resultName": "transactions",
      "schema": "datalake",
      "table": "transactions",
      "columns": [
        "amount"
      ]
    },
    {
      "type": "Transformation",
      "resultName": "monthly_trend",
      "sql": "SELECT ifw_effective_date, COUNT(*) AS daily_transactions, ROUND(SUM(amount), 2) AS daily_amount, ROUND(AVG(amount), 2) AS avg_transaction_amount FROM transactions GROUP BY ifw_effective_date ORDER BY ifw_effective_date"
    },
    {
      "type": "CsvFileWriter",
      "source": "monthly_trend",
      "includeHeader": true,
      "writeMode": "Append",
      "lineEnding": "LF",
      "outputDirectory": "Output/poc4",
      "jobDirName": "monthly_transaction_trend",
      "fileName": "monthly_transaction_trend.csv"
    }
  ]
}
