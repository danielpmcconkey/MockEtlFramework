{
  "jobName": "CardTypeDistributionV2",
  "firstEffectiveDate": "2024-10-01",
  "modules": [
    {
      "type": "DataSourcing",
      "resultName": "cards",
      "schema": "datalake",
      "table": "cards",
      "columns": [
        "card_type"
      ]
    },
    {
      "type": "Transformation",
      "resultName": "output",
      "sql": "SELECT card_type, COUNT(*) AS card_count, CAST(COUNT(*) AS REAL) / CAST((SELECT COUNT(*) FROM cards) AS REAL) AS pct_of_total, (SELECT ifw_effective_date FROM cards LIMIT 1) AS ifw_effective_date FROM cards GROUP BY card_type ORDER BY card_type"
    },
    {
      "type": "CsvFileWriter",
      "source": "output",
      "includeHeader": true,
      "trailerFormat": "TRAILER|{row_count}|{date}",
      "writeMode": "Overwrite",
      "lineEnding": "LF",
      "outputDirectory": "Output/poc4",
      "jobDirName": "card_type_distribution",
      "fileName": "card_type_distribution.csv"
    }
  ]
}
