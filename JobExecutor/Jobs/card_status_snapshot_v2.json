{
  "jobName": "CardStatusSnapshotV2",
  "firstEffectiveDate": "2024-10-01",
  "modules": [
    {
      "type": "DataSourcing",
      "resultName": "cards",
      "schema": "datalake",
      "table": "cards",
      "columns": [
        "card_status"
      ]
    },
    {
      "type": "Transformation",
      "resultName": "output",
      "sql": "SELECT c.card_status, COUNT(*) AS card_count, c.ifw_effective_date FROM cards c GROUP BY c.card_status, c.ifw_effective_date"
    },
    {
      "type": "ParquetFileWriter",
      "source": "output",
      "outputDirectory": "Output/poc4",
      "numParts": 50,
      "writeMode": "Overwrite",
      "jobDirName": "card_status_snapshot",
      "fileName": "card_status_snapshot"
    }
  ]
}
