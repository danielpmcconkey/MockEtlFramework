{
  "jobName": "CreditScoreSnapshotV2",
  "firstEffectiveDate": "2024-10-01",
  "modules": [
    {
      "type": "DataSourcing",
      "resultName": "credit_scores",
      "schema": "datalake",
      "table": "credit_scores",
      "columns": [
        "credit_score_id",
        "customer_id",
        "bureau",
        "score"
      ]
    },
    {
      "type": "Transformation",
      "resultName": "output",
      "sql": "SELECT credit_score_id, customer_id, bureau, score, SUBSTR(ifw_effective_date, 6, 2) || '/' || SUBSTR(ifw_effective_date, 9, 2) || '/' || SUBSTR(ifw_effective_date, 1, 4) AS ifw_effective_date FROM credit_scores"
    },
    {
      "type": "CsvFileWriter",
      "source": "output",
      "includeHeader": true,
      "writeMode": "Overwrite",
      "lineEnding": "CRLF",
      "outputDirectory": "Output/poc4",
      "jobDirName": "credit_score_snapshot",
      "fileName": "credit_score_snapshot.csv"
    }
  ]
}
