{
  "jobName": "OverdraftFeeSummaryV2",
  "firstEffectiveDate": "2024-10-01",
  "modules": [
    {
      "type": "DataSourcing",
      "resultName": "overdraft_events",
      "schema": "datalake",
      "table": "overdraft_events",
      "columns": ["fee_amount", "fee_waived"]
    },
    {
      "type": "Transformation",
      "resultName": "fee_summary",
      "sql": "SELECT oe.fee_waived, ROUND(SUM(oe.fee_amount), 2) AS total_fees, COUNT(*) AS event_count, ROUND(AVG(oe.fee_amount), 2) AS avg_fee, oe.as_of FROM overdraft_events oe GROUP BY oe.fee_waived, oe.as_of ORDER BY oe.fee_waived"
    },
    {
      "type": "CsvFileWriter",
      "source": "fee_summary",
      "outputFile": "Output/double_secret_curated/overdraft_fee_summary.csv",
      "includeHeader": true,
      "writeMode": "Overwrite",
      "lineEnding": "LF"
    }
  ]
}
