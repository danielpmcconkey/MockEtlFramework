{
  "jobName": "TransactionCategorySummaryV2",
  "firstEffectiveDate": "2024-10-01",
  "modules": [
    {
      "type": "DataSourcing",
      "resultName": "transactions",
      "schema": "datalake",
      "table": "transactions",
      "columns": [
        "txn_type",
        "amount"
      ]
    },
    {
      "type": "Transformation",
      "resultName": "txn_cat_summary",
      "sql": "SELECT t.txn_type, t.ifw_effective_date, ROUND(SUM(t.amount), 2) AS total_amount, COUNT(*) AS transaction_count, ROUND(AVG(t.amount), 2) AS avg_amount FROM transactions t GROUP BY t.txn_type, t.ifw_effective_date ORDER BY t.ifw_effective_date, t.txn_type"
    },
    {
      "type": "CsvFileWriter",
      "source": "txn_cat_summary",
      "includeHeader": true,
      "trailerFormat": "END|{row_count}",
      "writeMode": "Append",
      "lineEnding": "LF",
      "outputDirectory": "Output/poc4",
      "jobDirName": "transaction_category_summary",
      "fileName": "transaction_category_summary.csv"
    }
  ]
}
